# =============================================================================
# Phloz env template
# =============================================================================
# 1. Copy this file to `.env.local` at the repo root AND into each app that
#    needs it: `apps/web/.env.local` and `apps/app/.env.local`.
#    Next.js only auto-loads env files inside the app directory it's running.
# 2. Fill in values. Everything is validated at startup by
#    `packages/config/src/env.ts` (Zod schema). Missing optional vars are fine;
#    `requireEnv()` will throw at the call site only when actually needed.
# 3. NEVER commit `.env.local`. It's gitignored. Secrets stay local + Vercel.
#
# Legend:
#   [web]  needed by apps/web (marketing site)
#   [app]  needed by apps/app (product)
#   [both] needed by both
#   NEXT_PUBLIC_*  exposed to the browser — safe to ship, DO NOT put secrets here
# =============================================================================

NODE_ENV=development


# -----------------------------------------------------------------------------
# Supabase  [both]
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → API
#
# Key format note (2026): Supabase has migrated from legacy JWT-based keys to
# prefixed keys. Prefer the new format:
#   • Public key  → starts with `sb_publishable_...`  (was: `anon` JWT)
#   • Secret key  → starts with `sb_secret_...`       (was: `service_role` JWT)
# Both slots below accept either format — supabase-js detects automatically.
# The env var names stay the same for backwards compatibility.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# Direct Postgres connection string. Used by Drizzle (migrations, seed) and
# any server code that bypasses PostgREST.
# Dashboard → Project Settings → Database → Connection string.
#   • Prefer the Transaction pooler (port 6543) for serverless / Vercel.
#     Example: postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:6543/postgres
#   • Use the direct URI (port 5432) only for long-running migrations / seeds
#     if the pooler disconnects on you.
DATABASE_URL=


# -----------------------------------------------------------------------------
# Stripe  [app]
# -----------------------------------------------------------------------------
# Dashboard → Developers → API keys. Use the **sandbox** (test-mode) account
# for local dev; swap to live-mode keys only on the production Vercel project.
# Price IDs live in `packages/billing/src/tiers.ts` (not env).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
# From `stripe listen --forward-to …` locally, or Dashboard → Webhooks on prod.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Resend (outbound + inbound email)  [app]
# -----------------------------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
# Shared secret configured on the inbound webhook; verified in the route handler.
RESEND_WEBHOOK_SECRET=
# Domains must be verified in Resend (SPF, DKIM, DMARC). See docs/DNS-SETUP.md.
EMAIL_FROM_DOMAIN=phloz.com
INBOUND_EMAIL_DOMAIN=inbound.phloz.com


# -----------------------------------------------------------------------------
# Analytics  [both]
# -----------------------------------------------------------------------------
# GTM loads on both apps. GA4 + PostHog keys are optional in dev — the
# `track()` helper no-ops when keys are missing.
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-W3MGZ8V7
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4 Measurement Protocol API secret (server-side events: sign_up, upgrade_tier).
# Admin → Data Streams → [stream] → Measurement Protocol API secrets.
GA4_API_SECRET=
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# -----------------------------------------------------------------------------
# Sentry  [both]
# -----------------------------------------------------------------------------
# Same DSN in both vars is fine; the public one is exposed to the client
# bundle, the server one stays server-only (identical value, different scope).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# For source-map upload during build (CI / Vercel only — not needed locally).
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# Inngest (background jobs)  [app]
# -----------------------------------------------------------------------------
# Empty in local dev → Inngest runs against the local dev server.
# Fill in for preview/production from https://app.inngest.com → Settings → Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# -----------------------------------------------------------------------------
# App URLs  [both]
# -----------------------------------------------------------------------------
# Used for absolute links (emails, OAuth callbacks, canonical tags, CORS).
# Override in Vercel with the real domains for preview/prod.
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
