# Copy to .env.local and fill in values.
# Validated at startup by packages/config/src/env.ts.

NODE_ENV=development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL for Drizzle migrations + server queries
DATABASE_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM_DOMAIN=phloz.com
INBOUND_EMAIL_DOMAIN=inbound.phloz.com

# --- Analytics ---
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-W3MGZ8V7
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
GA4_API_SECRET=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
